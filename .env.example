# Example environment variables
# Copy this to .env.local (local dev) or .env (docker compose) and fill in values

# Site Configuration
NEXT_PUBLIC_SITE_NAME=Varun TM
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ============================================================
# Admin CMS (REQUIRED to use the /admin panel)
# ============================================================
# Password you type at /admin/login
ADMIN_PASSWORD=change-me-to-something-strong
# Secret used to sign the admin session cookie. MIN 16 chars.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string-min-16-chars
# Optional: override where editable content is stored (defaults to ./data)
# DATA_DIR=/app/data

# Email Configuration (Optional - for form submissions)
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# API Keys (Optional)
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=your_stripe_key
